APP_PORT=8000
APP_ENV=development

# DB_DRIVER: postgres | mysql
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nitip
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSLMODE=disable

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

FIREBASE_CREDENTIALS_FILE=./firebase-credentials.json

# Admin password for CLI commands (register-client, etc.)
ADMIN_PASSWORD=nitip-admin-2026

# JWT Secret (REQUIRED in production — generate with: openssl rand -hex 32)
# If not set in production (APP_ENV=production), server will refuse to start
JWT_SECRET=

# Auth Master Key for API Client secret encryption (AES-256, REQUIRED in production)
# Generate with: openssl rand -hex 32
AUTH_MASTER_KEY=

# CORS Allowed Origins (comma-separated, only used when APP_ENV=production)
# Defaults to "https://nitip.id,https://admin.nitip.id" in production
CORS_ALLOWED_ORIGINS=

# Midtrans Payment Gateway
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# Use Mock Payment (true = mock-qris, false = Midtrans)
USE_MOCK_PAYMENT=true

# Webhook Callback Token (REQUIRED in production — generate: openssl rand -hex 16)
# Used to authenticate payment gateway webhook callbacks (QRIS & Disbursement)
WEBHOOK_CALLBACK_TOKEN=
